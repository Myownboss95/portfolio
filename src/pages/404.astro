---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page doesn’t exist.">
  <section class="mx-auto flex max-w-2xl flex-col items-start px-5 py-28">
    <p class="font-mono text-sm text-accent">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-main sm:text-5xl">
      This page took a wrong turn.
    </h1>
    <p class="mt-4 text-lg text-muted">
      The page you’re looking for doesn’t exist or has moved.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/" class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-[#06140f] transition hover:opacity-90">
        Back home
      </a>
      <a href="/work" class="rounded-lg border border-app px-5 py-2.5 text-sm font-semibold text-main transition hover:border-accent hover:text-accent">
        View work
      </a>
    </div>
  </section>
</BaseLayout>
