---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../consts';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = projects.filter((p) => p.data.featured).slice(0, 4);

const skills = [
  { group: 'Backend', items: ['PHP / Laravel (8+ yrs)', 'Node.js / NestJS (5+ yrs)', 'TypeScript', 'REST API design', 'WebSockets', 'Redis queues'] },
  { group: 'Payments', items: ['Virtual card issuance', 'Cross-border FX & remittance', 'KYC / AML pipelines', 'Webhook architecture', 'Event-driven integrations'] },
  { group: 'Frontend & Mobile', items: ['Vue / Nuxt (5+ yrs)', 'React / Next (4+ yrs)', 'Tailwind CSS', 'Flutter / Dart'] },
  { group: 'DevOps & Security', items: ['Docker', 'CI/CD', 'AWS / DigitalOcean', 'Cloudflare WAF', 'OWASP Top 10', 'E2E encryption'] },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pb-16 pt-20 sm:pt-28">
    <p class="mb-4 font-mono text-sm text-accent">{SITE.location} · Open to remote roles</p>
    <h1 class="max-w-3xl text-4xl font-bold leading-[1.1] tracking-tight text-main sm:text-5xl md:text-6xl">
      I build the backend that moves money — securely, at scale.
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
      Senior backend-heavy fullstack engineer & technical lead with <strong class="text-main">8+ years</strong>
      shipping production fintech: cross-border payments, virtual card issuance, KYC/AML, and
      end-to-end encryption. Former CTO at a pan-African neobank.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/work" class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-[#06140f] transition hover:opacity-90">
        View my work
      </a>
      <a href="/contact" class="rounded-lg border border-app px-5 py-2.5 text-sm font-semibold text-main transition hover:border-accent hover:text-accent">
        Get in touch
      </a>
      <a href={SITE.resumeUrl} class="rounded-lg border border-app px-5 py-2.5 text-sm font-semibold text-main transition hover:border-accent hover:text-accent">
        Download résumé
      </a>
    </div>
  </section>

  <!-- Featured work -->
  <section class="border-t border-app bg-soft">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-main">Selected work</h2>
          <p class="mt-1 text-muted">Production systems, told as case studies — not code dumps.</p>
        </div>
        <a href="/work" class="hidden text-sm font-medium text-accent hover:underline sm:inline">All work →</a>
      </div>

      {
        featured.length > 0 ? (
          <div class="grid gap-5 sm:grid-cols-2">
            {featured.map((project) => <ProjectCard project={project} />)}
          </div>
        ) : (
          <p class="text-muted">Case studies coming soon.</p>
        )
      }
    </div>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-5xl px-5 py-16">
    <h2 class="text-2xl font-bold tracking-tight text-main">What I work with</h2>
    <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        skills.map((col) => (
          <div>
            <h3 class="mb-3 font-mono text-sm font-semibold text-accent">{col.group}</h3>
            <ul class="space-y-1.5">
              {col.items.map((item) => (
                <li class="text-sm text-muted">{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-app">
    <div class="mx-auto max-w-5xl px-5 py-16 text-center">
      <h2 class="text-2xl font-bold tracking-tight text-main">Looking for a senior backend / fullstack engineer?</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted">
        I’m open to remote roles. Let’s talk about what you’re building.
      </p>
      <a href="/contact" class="mt-6 inline-block rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-[#06140f] transition hover:opacity-90">
        Contact me
      </a>
    </div>
  </section>
</BaseLayout>
