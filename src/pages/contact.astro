---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { SITE, SOCIALS, STATUS } from '../consts';

// ── Contact form ─────────────────────────────────────────────────────────────
// Uses Web3Forms (free, no backend). To activate:
//   1. Get a free access key at https://web3forms.com (enter your email).
//   2. Paste it below. Submissions arrive in your inbox — no server required.
// Until a real key is set, the form is disabled and the email link is the CTA.
const WEB3FORMS_KEY = 'e854f529-8c39-47bb-a838-12b0d5c3d88c';
const formEnabled = WEB3FORMS_KEY !== 'YOUR-WEB3FORMS-ACCESS-KEY';
---

<BaseLayout title="Contact" description="Get in touch with Daniel Odiachi about senior AI / LLM and backend engineering roles, remote or on-site.">
  <section class="mx-auto max-w-2xl px-5 py-16">
    <p class="mb-4 flex flex-wrap items-center gap-x-2.5 gap-y-1 font-mono text-sm">
      {STATUS.available && <span class="status-dot" aria-hidden="true" />}
      <span class="text-accent">{STATUS.label}</span>
      <span class="text-faint">· {STATUS.detail}</span>
    </p>
    <h1 class="text-3xl font-bold tracking-tight text-main sm:text-4xl">Get in touch</h1>
    <p class="mt-3 text-lg text-muted">
      Whether it’s LLM/RAG work or the backend systems underneath it, I’d like to hear about it.
      The fastest way to reach me is email — or use the form below.
    </p>

    <!-- Direct links -->
    <!-- Contact page keeps the handle visible — this is where the detail is
         useful — with the icon leading it. -->
    <ul class="mt-6 flex flex-wrap gap-3" role="list">
      {
        SOCIALS.map((s) => {
          const external = s.href.startsWith('http');
          return (
            <li>
              <a
                href={s.href}
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener noreferrer' : undefined}
                class="social-link flex items-center gap-2.5 rounded-lg border border-app bg-card px-4 py-2 text-sm font-medium text-main"
              >
                <span class="social-glyph shrink-0 text-muted">
                  <SocialIcon label={s.label} size={18} />
                </span>
                <span>
                  {s.label} <span class="text-faint">· {s.handle}</span>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Form -->
    <form
      id="contact-form"
      action="https://api.web3forms.com/submit"
      method="POST"
      class="mt-10 space-y-4"
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New message from danielodiachi.work" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <div>
        <label for="name" class="mb-1 block text-sm font-medium text-main">Name</label>
        <input id="name" name="name" type="text" required class="w-full rounded-lg border border-app bg-soft px-3 py-2.5 text-main placeholder:text-faint focus:border-accent" placeholder="Your name" />
      </div>
      <div>
        <label for="email" class="mb-1 block text-sm font-medium text-main">Email</label>
        <input id="email" name="email" type="email" required class="w-full rounded-lg border border-app bg-soft px-3 py-2.5 text-main placeholder:text-faint focus:border-accent" placeholder="you@company.com" />
      </div>
      <div>
        <label for="message" class="mb-1 block text-sm font-medium text-main">Message</label>
        <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-app bg-soft px-3 py-2.5 text-main placeholder:text-faint focus:border-accent" placeholder="Tell me about the role or project…"></textarea>
      </div>

      <button
        type="submit"
        disabled={!formEnabled}
        class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-[#06140f] transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
      >
        Send message
      </button>

      {!formEnabled && (
        <p class="text-sm text-faint">
          Form not yet activated — add a free Web3Forms key in <code class="font-mono">contact.astro</code>.
          Meanwhile, email me at <a href={`mailto:${SITE.email}`} class="text-accent hover:underline">{SITE.email}</a>.
        </p>
      )}

      <p id="form-status" class="hidden text-sm"></p>
    </form>
  </section>

  <style>
    .social-link {
      transition:
        color 0.15s ease,
        border-color 0.15s ease,
        background-color 0.15s ease,
        transform 0.15s ease;
    }
    .social-link:hover {
      color: var(--accent);
      border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
      background: color-mix(in srgb, var(--accent) 8%, var(--bg-card));
      transform: translateY(-2px);
    }
    .social-glyph {
      transition: color 0.15s ease;
    }
    .social-link:hover .social-glyph,
    .social-link:focus-visible .social-glyph {
      color: var(--accent);
    }

    @media (prefers-reduced-motion: reduce) {
      .social-link,
      .social-glyph {
        transition: none;
      }
      .social-link:hover {
        transform: none;
      }
    }
  </style>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    if (form && !form.querySelector('button').disabled) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        status.className = 'text-sm text-muted';
        status.classList.remove('hidden');
        status.textContent = 'Sending…';
        try {
          const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
          if (res.ok) {
            form.reset();
            status.className = 'text-sm text-accent';
            status.textContent = 'Thanks — your message is on its way. I’ll reply by email.';
          } else {
            throw new Error('Request failed');
          }
        } catch {
          status.className = 'text-sm text-red-400';
          status.textContent = 'Something went wrong. Please email me directly instead.';
        }
      });
    }
  </script>
</BaseLayout>
