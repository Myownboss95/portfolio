---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SiteCard from '../../components/SiteCard.astro';
import { SITES } from '../../data/sites';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Group case studies into tracks for the filter. A project can belong to more
// than one (the KYC work is both AI and Security). Derived from the existing
// `domain` tags — no schema change, no per-file maintenance.
const TRACKS = [
  { id: 'ai', label: 'AI & LLM', domains: ['AI', 'LLM', 'RAG', 'Agents', 'MCP'] },
  { id: 'payments', label: 'Payments', domains: ['Payments', 'Fintech'] },
  { id: 'security', label: 'Security & KYC', domains: ['Security', 'KYC'] },
] as const;

const tracksFor = (domain: string[]) =>
  TRACKS.filter((t) => domain.some((d) => (t.domains as readonly string[]).includes(d))).map(
    (t) => t.id
  );

// Only offer a filter that actually matches something.
const activeTracks = TRACKS.filter((t) =>
  projects.some((p) => tracksFor(p.data.domain).includes(t.id))
);
---

<BaseLayout title="Work" description="Case studies from production fintech systems — payments, card issuance, KYC, and security — plus web & WordPress builds.">
  <section class="mx-auto max-w-5xl px-5 py-16">
    <!-- Header -->
    <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-accent">Case studies</p>
    <h1 class="mt-4 text-4xl font-bold leading-[1.08] tracking-tight text-main sm:text-5xl lg:text-6xl">
      Production systems,
      <span class="block text-faint">documented end to end.</span>
    </h1>
    <p class="mt-5 max-w-2xl text-lg text-muted">
      Payments, card issuance, KYC and AI infrastructure — mostly private source, so
      the engineering lives in the write-up.
    </p>

    <!-- Filter -->
    {
      activeTracks.length > 1 && (
        <div class="mt-10">
          <div
            class="inline-flex flex-wrap items-center gap-1 rounded-xl border border-app bg-soft p-1"
            role="group"
            aria-label="Filter case studies by track"
          >
            <button
              type="button"
              class="track-filter rounded-lg border border-app bg-card px-3.5 py-1.5 font-mono text-xs text-main shadow-sm transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
              data-track="all"
              aria-pressed="true"
            >
              All
            </button>
            {activeTracks.map((track) => (
              <button
                type="button"
                class="track-filter rounded-lg border border-transparent px-3.5 py-1.5 font-mono text-xs text-muted transition hover:text-main focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                data-track={track.id}
                aria-pressed="false"
              >
                {track.label}
              </button>
            ))}
          </div>
        </div>
      )
    }

    {
      projects.length > 0 ? (
        <div id="project-grid" class="mt-8 grid gap-6 sm:grid-cols-2">
          {projects.map((project) => (
            <div data-tracks={tracksFor(project.data.domain).join(' ')}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
      ) : (
        <p class="mt-8 text-muted">Case studies coming soon.</p>
      )
    }

    <!-- Web & WordPress -->
    {
      SITES.length > 0 && (
        <>
          <h2 class="mt-16 font-mono text-sm font-semibold uppercase tracking-wider text-accent">Web &amp; WordPress</h2>
          <p class="mt-2 max-w-2xl text-muted">
            Client websites and WordPress builds — design, development, and deployment.
          </p>
          <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {SITES.map((site) => <SiteCard site={site} />)}
          </div>
        </>
      )
    }
  </section>

  <script is:inline>
    // Case-study track filter. Progressive enhancement: with JS off every card
    // is already rendered and visible, and the buttons simply never appear
    // (they're only useful once this runs).
    (() => {
      const buttons = document.querySelectorAll('.track-filter');
      const grid = document.getElementById('project-grid');
      if (!buttons.length || !grid) return;

      // Segmented control: the active segment is a raised inset panel.
      const on = ['border-app', 'bg-card', 'text-main', 'shadow-sm'];
      const off = ['border-transparent', 'text-muted', 'hover:text-main'];

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const track = btn.dataset.track;

          buttons.forEach((b) => {
            const active = b === btn;
            b.setAttribute('aria-pressed', String(active));
            b.classList.remove(...(active ? off : on));
            b.classList.add(...(active ? on : off));
          });

          grid.querySelectorAll('[data-tracks]').forEach((card) => {
            const match = track === 'all' || card.dataset.tracks.split(' ').includes(track);
            card.hidden = !match;
          });
        });
      });
    })();
  </script>
</BaseLayout>
