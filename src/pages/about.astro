---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { SITE, SOCIALS } from '../consts';
// Shared with the homepage's "Professional Journey" section — one source of truth.
import { experience } from '../data/experience';
---

<BaseLayout title="About" description="Senior Full Stack & AI Engineer — LLM systems (RAG, agents, MCP) built on 8+ years of production fintech and payments infrastructure.">
  <section class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-main sm:text-4xl">About</h1>

    <div class="prose-case mt-6">
      <p>
        I’m a senior <strong>full stack and AI engineer</strong> with 8+ years shipping production
        systems across fintech, web, and mobile. Today a large part of my work is
        <strong>LLM products in production</strong> — Retrieval-Augmented Generation pipelines with
        vector and keyword retrieval, agentic workflows that take real actions through tool-use,
        LLM-assisted document extraction, and a custom <strong>Model Context Protocol (MCP) server</strong>
        exposing internal tools to agents, built on Anthropic Claude and OpenAI.
      </p>
      <p>
        That work sits on top of eight years of infrastructure that had to be correct. As CTO at
        <strong>Hizo Africa</strong>, a pan-African neobank, I led a team of 6 and owned the core
        architecture — the cross-border RateEngine, the tiered KYC platform, virtual card issuance,
        and an end-to-end encryption layer.
      </p>
      <p>
        My depth is in <strong>Laravel / PHP (8+ yrs)</strong> and <strong>TypeScript / Node.js</strong>,
        with <strong>Go</strong> and <strong>Python</strong> in service-level work — plus React/Next
        and Vue/Nuxt on the frontend. The through-line is the same whether the
        system is a payment rail or an agent: I care about correctness, grounding, and being able to
        prove the thing actually works.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href={SITE.resumeUrl} class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-[#06140f] transition hover:opacity-90">
        Download résumé
      </a>
      <!-- Icon-only tiles. The visible label is gone, so each link keeps a
           discernible name via aria-label; the glyph is aria-hidden. -->
      <ul class="flex flex-wrap items-center gap-2" role="list">
        {SOCIALS.map((s) => {
          const external = s.href.startsWith('http');
          return (
            <li>
              <a
                href={s.href}
                aria-label={s.label}
                title={s.label}
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener noreferrer' : undefined}
                class="social-tile flex h-11 w-11 items-center justify-center rounded-lg border border-app bg-card text-muted"
              >
                <SocialIcon label={s.label} size={20} />
              </a>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- Experience timeline. Each role is a native <details> so the accordion
         works with zero JS and stays keyboard/screen-reader accessible. -->
    <div class="mt-16 flex flex-wrap items-center justify-between gap-3">
      <h2 class="text-2xl font-bold tracking-tight text-main">Experience</h2>
      <!-- Progressive enhancement only: hidden until the script below unhides it,
           so no-JS visitors never see a dead control. -->
      <button
        id="exp-toggle-all"
        type="button"
        hidden
        class="rounded-lg border border-app px-3 py-1.5 font-mono text-xs text-muted transition hover:border-accent hover:text-accent"
        aria-controls="experience-list"
      >
        Expand all
      </button>
    </div>

    <div id="experience-list" class="mt-8 space-y-4 border-l border-app pl-6">
      {
        experience.map((job, i) => (
          <ExperienceItem job={job} index={i} open={i === 0} />
        ))
      }
    </div>

    <!-- Education -->
    <h2 class="mt-16 text-2xl font-bold tracking-tight text-main">Education</h2>
    <div class="mt-6 space-y-3">
      <div>
        <p class="font-semibold text-main">B.Eng, Mechanical Engineering</p>
        <p class="text-sm text-muted">Federal University of Technology, Owerri (FUTO) · 2011 — 2016</p>
      </div>
      <div>
        <p class="font-semibold text-main">Certification, Software Development</p>
        <p class="text-sm text-muted">Compunet Technologies · 2018</p>
      </div>
    </div>
  </section>

  <style>
    .social-tile {
      transition:
        color 0.15s ease,
        border-color 0.15s ease,
        background-color 0.15s ease,
        transform 0.15s ease;
    }
    .social-tile:hover {
      color: var(--accent);
      border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
      background: color-mix(in srgb, var(--accent) 8%, var(--bg-card));
      transform: translateY(-2px);
    }
    .social-tile:focus-visible {
      color: var(--accent);
    }

    @media (prefers-reduced-motion: reduce) {
      .social-tile {
        transition: none;
      }
      .social-tile:hover {
        transform: none;
      }
    }
  </style>

  <script is:inline>
    // Expand/collapse-all for the experience accordion. Pure enhancement: the
    // <details> elements are fully usable on their own, so the button only
    // appears once this runs.
    (function () {
      var list = document.getElementById('experience-list');
      var btn = document.getElementById('exp-toggle-all');
      if (!list || !btn) return;

      var items = Array.prototype.slice.call(list.querySelectorAll('details'));
      if (!items.length) return;

      btn.hidden = false;

      function sync() {
        // "Expand all" until every role is open, then it flips to collapse.
        var allOpen = items.every(function (d) {
          return d.open;
        });
        btn.textContent = allOpen ? 'Collapse all' : 'Expand all';
        btn.setAttribute('aria-expanded', String(allOpen));
      }

      btn.addEventListener('click', function () {
        var expand = !items.every(function (d) {
          return d.open;
        });
        items.forEach(function (d) {
          d.open = expand;
        });
        sync();
      });

      // Keep the label honest when individual rows are toggled directly.
      items.forEach(function (d) {
        d.addEventListener('toggle', sync);
      });

      sync();
    })();
  </script>
</BaseLayout>
