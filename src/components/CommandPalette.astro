---
// ⌘K palette. The index is built at BUILD time from the same consts and content
// collection the rest of the site renders from, so it can never drift out of
// sync with the nav or the case studies. Ships as inert JSON + one inline script.
import { getCollection } from 'astro:content';
import { SITE, NAV, SOCIALS } from '../consts';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

type Item = {
  section: 'Pages' | 'Case studies' | 'Links';
  title: string;
  href: string;
  hint?: string;
  newTab?: boolean;
};

const items: Item[] = [
  { section: 'Pages', title: 'Home', href: '/' },
  ...NAV.map((n) => ({ section: 'Pages' as const, title: n.label, href: n.href })),
  ...projects.map((p) => ({
    section: 'Case studies' as const,
    title: p.data.title,
    href: `/work/${p.id}`,
    hint: p.data.company,
  })),
  { section: 'Links', title: 'Résumé (PDF)', href: SITE.resumeUrl, hint: 'Download', newTab: true },
  ...SOCIALS.map((s) => ({
    section: 'Links' as const,
    title: s.label,
    href: s.href,
    hint: s.handle,
    // mailto:/tel: must stay in-page or the browser opens a blank tab.
    newTab: s.href.startsWith('http'),
  })),
];

// Section render order — stable groups read better than relevance-shuffled ones.
const sections = ['Pages', 'Case studies', 'Links'];
---

<!-- Starts hidden and stays hidden without JS: the trigger is revealed by the
     script below, and nothing here is focusable while `hidden` is applied. -->
<div id="cmdk" class="cmdk fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-label="Command palette">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-cmdk-backdrop></div>

  <div class="cmdk-panel relative mx-auto mt-[12vh] flex max-h-[70vh] w-[calc(100%-2rem)] max-w-lg flex-col overflow-hidden rounded-xl border border-app bg-card shadow-2xl">
    <div class="flex items-center gap-3 border-b border-app px-4">
      <svg class="h-4 w-4 shrink-0 text-faint" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" />
      </svg>
      <input
        id="cmdk-input"
        type="text"
        role="combobox"
        aria-expanded="true"
        aria-controls="cmdk-list"
        aria-autocomplete="list"
        aria-label="Search pages, case studies and links"
        placeholder="Search pages, case studies, links…"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        class="w-full bg-transparent py-3.5 text-sm text-main outline-none placeholder:text-faint"
      />
      <kbd class="hidden shrink-0 rounded border border-app px-1.5 py-0.5 font-mono text-[10px] text-faint sm:block">esc</kbd>
    </div>

    <div id="cmdk-list" role="listbox" aria-label="Results" class="flex-1 overflow-y-auto p-2"></div>

    <p id="cmdk-empty" class="hidden px-4 py-8 text-center text-sm text-muted">No matches.</p>

    <div class="flex items-center gap-4 border-t border-app px-4 py-2 font-mono text-[10px] text-faint">
      <span>↑↓ navigate</span><span>↵ open</span><span>esc close</span>
    </div>
  </div>
</div>

<script id="cmdk-data" type="application/json" set:html={JSON.stringify({ items, sections })} is:inline></script>

<style>
  /* Panel entrance. Kept local so global.css stays the token layer. */
  .cmdk-panel {
    animation: cmdk-in 140ms ease-out;
  }
  @keyframes cmdk-in {
    from {
      opacity: 0;
      transform: translateY(-8px) scale(0.98);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cmdk-panel {
      animation: none;
    }
  }
</style>

<script is:inline>
  (function () {
    const root = document.getElementById('cmdk');
    const input = document.getElementById('cmdk-input');
    const list = document.getElementById('cmdk-list');
    const empty = document.getElementById('cmdk-empty');
    const data = JSON.parse(document.getElementById('cmdk-data').textContent);

    let results = [];
    let active = 0;
    let opener = null;

    // Substring first, subsequence second — so "vcard" still finds "Virtual Card"
    // while exact matches always outrank the loose ones.
    function score(text, q) {
      const t = text.toLowerCase();
      const direct = t.indexOf(q);
      if (direct !== -1) return 1000 - direct;
      let from = 0;
      let last = -1;
      let bonus = 0;
      for (const ch of q) {
        const at = t.indexOf(ch, from);
        if (at === -1) return -1;
        if (at === last + 1) bonus += 2;
        last = at;
        from = at + 1;
      }
      return 100 + bonus - last;
    }

    function filter(q) {
      q = q.trim().toLowerCase();
      if (!q) return data.items.slice();
      return data.items
        .map((item) => ({ item, s: score(item.title + ' ' + item.section, q) }))
        .filter((r) => r.s >= 0)
        .sort((a, b) => b.s - a.s)
        .map((r) => r.item);
    }

    function render(q) {
      results = filter(q);
      active = 0;
      list.textContent = '';
      empty.classList.toggle('hidden', results.length > 0);

      data.sections.forEach((section) => {
        const group = results.filter((r) => r.section === section);
        if (!group.length) return;

        const label = document.createElement('div');
        label.className = 'px-2 pb-1 pt-3 font-mono text-[10px] uppercase tracking-wider text-faint';
        label.textContent = section;
        list.append(label);

        group.forEach((item) => {
          const row = document.createElement('div');
          row.className =
            'cmdk-row flex cursor-pointer items-center justify-between gap-3 rounded-lg px-2 py-2 text-sm text-muted';
          row.setAttribute('role', 'option');
          row.id = 'cmdk-opt-' + results.indexOf(item);
          row.dataset.index = String(results.indexOf(item));

          const title = document.createElement('span');
          title.className = 'truncate';
          title.textContent = item.title;
          row.append(title);

          if (item.hint) {
            const hint = document.createElement('span');
            hint.className = 'shrink-0 truncate font-mono text-xs text-faint';
            hint.textContent = item.hint;
            row.append(hint);
          }

          row.addEventListener('mousemove', () => setActive(Number(row.dataset.index)));
          row.addEventListener('click', () => go(Number(row.dataset.index)));
          list.append(row);
        });
      });

      setActive(0);
    }

    function setActive(i) {
      if (!results.length) return;
      active = (i + results.length) % results.length;
      list.querySelectorAll('.cmdk-row').forEach((row) => {
        const on = Number(row.dataset.index) === active;
        row.setAttribute('aria-selected', on ? 'true' : 'false');
        row.classList.toggle('bg-soft', on);
        row.classList.toggle('text-accent', on);
        if (on) {
          input.setAttribute('aria-activedescendant', row.id);
          row.scrollIntoView({ block: 'nearest' });
        }
      });
    }

    function go(i) {
      const item = results[i];
      if (!item) return;
      close();
      if (item.newTab) window.open(item.href, '_blank', 'noopener');
      else window.location.href = item.href;
    }

    function open() {
      if (!root.classList.contains('hidden')) return;
      opener = document.activeElement;
      root.classList.remove('hidden');
      // Lock the page behind the dialog so the backdrop doesn't scroll.
      document.body.style.overflow = 'hidden';
      input.value = '';
      render('');
      input.focus();
    }

    function close() {
      if (root.classList.contains('hidden')) return;
      root.classList.add('hidden');
      document.body.style.overflow = '';
      if (opener && typeof opener.focus === 'function') opener.focus();
      opener = null;
    }

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        root.classList.contains('hidden') ? open() : close();
        return;
      }
      if (root.classList.contains('hidden')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(active + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(active - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        go(active);
      } else if (e.key === 'Tab') {
        // The input is the only tabbable node in here, so trapping is just
        // refusing to let Tab hand focus back to the page behind the dialog.
        e.preventDefault();
        input.focus();
      }
    });

    root.querySelector('[data-cmdk-backdrop]').addEventListener('click', close);
    input.addEventListener('input', () => render(input.value));

    document.querySelectorAll('[data-cmdk-open]').forEach((btn) => {
      btn.addEventListener('click', open);
    });

    // Only advertise the palette once it can actually respond.
    document.documentElement.setAttribute('data-cmdk-ready', '');
  })();
</script>
