---
import type { Site } from '../data/sites';

interface Props {
  site: Site;
}

const { site } = Astro.props;
const host = site.url.replace(/^https?:\/\//, '').replace(/\/$/, '');
---

<a
  href={site.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col overflow-hidden rounded-xl border border-app bg-card transition hover:border-accent"
>
  <!-- Thumbnail, or a clean text fallback -->
  {
    site.thumb ? (
      <img src={site.thumb} alt={`${site.name} screenshot`} width="640" height="360" loading="lazy" class="aspect-video w-full object-cover" />
    ) : (
      <div class="flex aspect-video w-full items-center justify-center bg-soft">
        <span class="font-mono text-sm text-faint">{host}</span>
      </div>
    )
  }

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-semibold text-main transition group-hover:text-accent">{site.name}</h3>
      <svg class="mt-1 h-4 w-4 shrink-0 text-faint transition group-hover:text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
    </div>

    {site.blurb && <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{site.blurb}</p>}
    {site.role && <p class="mt-2 font-mono text-xs text-faint">{site.role}</p>}

    {
      site.tags && site.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {site.tags.map((t) => (
            <span class="rounded border border-app px-2 py-0.5 font-mono text-xs text-faint">{t}</span>
          ))}
        </div>
      )
    }
  </div>
</a>
