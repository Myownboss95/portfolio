---
/**
 * ProjectCover — the 16:9 media slab at the top of a case-study card.
 *
 * None of the case studies have screenshots (they're private fintech systems),
 * so when `cover` is absent we *generate* one: a deterministic, abstract
 * "system diagram" drawn as inline SVG. Same slug always produces the same
 * artwork; different slugs produce visibly different hues, motifs and layouts.
 *
 * It's self-contained (no network, no external images), theme-aware (hue comes
 * from the slug, lightness comes from the active theme) and purely decorative.
 */
interface Props {
  /** Stable seed — the project slug. */
  seed: string;
  /** Optional real cover image path (from frontmatter). */
  cover?: string;
  /** Alt text used only when a real image is present. */
  alt?: string;
  class?: string;
}

const { seed, cover, alt = '', class: className = '' } = Astro.props;

/* ---------------------------------------------------------------- seeded RNG */

// FNV-1a — small, fast, and stable across builds.
function hash(str: string): number {
  let h = 0x811c9dc5;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 0x01000193);
  }
  return h >>> 0;
}

// mulberry32 — deterministic float stream from a 32-bit seed.
function rng(seedNum: number) {
  let a = seedNum >>> 0;
  return () => {
    a = (a + 0x6d2b79f5) >>> 0;
    let t = a;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

// FNV's low bits are weakly mixed (the final multiply by an odd prime leaves
// them almost untouched), so anything derived with `% n` gets an avalanche pass
// first. Without this, motif selection clumps badly across similar slugs.
function fmix32(h: number): number {
  h ^= h >>> 16;
  h = Math.imul(h, 0x85ebca6b);
  h ^= h >>> 13;
  h = Math.imul(h, 0xc2b2ae35);
  h ^= h >>> 16;
  return h >>> 0;
}

const h0 = hash(seed);
const mixed = fmix32(h0);
const rand = rng(h0);
const between = (lo: number, hi: number) => lo + rand() * (hi - lo);
const r2 = (n: number) => Math.round(n * 100) / 100;

/* ------------------------------------------------------------------- palette */

// Hue A is spread across the wheel but biased to stay in the cool/teal-friendly
// half so covers never fight the teal accent. Hue B is an analogous partner.
const mixed2 = fmix32(h0 ^ 0x9e3779b9);
const hueA = 150 + ((mixed >>> 6) % 130); // 150–279: teal → blue → indigo/violet
// Analogous partner hue. Rolled back below hueA rather than allowed past ~295,
// so no cover ever drifts into hot pink/red territory.
const hueOffset = 28 + (mixed2 % 44);
const hueB = hueA + hueOffset > 295 ? hueA - hueOffset : hueA + hueOffset;

/* --------------------------------------------------------------------- motif */

const MOTIFS = ['nodes', 'arcs', 'layers', 'lanes'] as const;
const motif = MOTIFS[(mixed >>> 2) % MOTIFS.length];
// Mirroring doubles the number of distinct compositions per motif for free.
const flip = ((mixed >>> 17) & 1) === 1;

const W = 320;
const H = 180;
const flipT = flip ? `translate(${W},0) scale(-1,1)` : undefined;
const uid = `pc-${(h0 % 0xffffff).toString(36)}`;

type Node = { x: number; y: number; r: number };
type Edge = { a: Node; b: Node };
type Layer = { x: number; y: number; w: number; h: number };
type Lane = { x: number; w: number; boxes: { y: number; h: number }[] };
type Arc = { r: number; dash: string };

const nodes: Node[] = [];
const edges: Edge[] = [];
const layers: Layer[] = [];
const lanes: Lane[] = [];
const arcs: Arc[] = [];
const dots: Node[] = [];
const wires: string[] = [];

if (motif === 'nodes') {
  // Jittered 4x3 lattice, then connect each node to its nearest neighbours —
  // reads as a service/topology diagram without ever tangling.
  const cols = 4;
  const rows = 3;
  for (let c = 0; c < cols; c++) {
    for (let rw = 0; rw < rows; rw++) {
      if (rand() < 0.22) continue; // punch a few holes so it isn't a grid
      nodes.push({
        x: r2(38 + (c * (W - 76)) / (cols - 1) + between(-14, 14)),
        y: r2(34 + (rw * (H - 68)) / (rows - 1) + between(-12, 12)),
        r: r2(between(2.6, 5.6)),
      });
    }
  }
  for (let i = 0; i < nodes.length; i++) {
    const near = nodes
      .filter((_, j) => j !== i)
      .map((n) => ({ n, d: Math.hypot(n.x - nodes[i].x, n.y - nodes[i].y) }))
      .sort((p, q) => p.d - q.d)
      .slice(0, rand() < 0.5 ? 2 : 1);
    near.forEach(({ n }) => {
      const dup = edges.some(
        (e) => (e.a === n && e.b === nodes[i]) || (e.a === nodes[i] && e.b === n)
      );
      if (!dup) edges.push({ a: nodes[i], b: n });
    });
  }
} else if (motif === 'arcs') {
  // Concentric arcs radiating from an off-canvas origin — "fan-out / broadcast".
  const count = 5 + Math.floor(rand() * 3);
  for (let i = 0; i < count; i++) {
    const r = r2(34 + i * between(18, 26));
    arcs.push({ r, dash: rand() < 0.35 ? '5 7' : 'none' });
  }
  const dotCount = 4 + Math.floor(rand() * 3);
  for (let i = 0; i < dotCount; i++) {
    const a = between(-1.15, 0.5);
    const r = arcs[Math.floor(rand() * arcs.length)].r;
    dots.push({ x: r2(34 + Math.cos(a) * r), y: r2(H - 26 + Math.sin(a) * r), r: r2(between(2.4, 4.6)) });
  }
} else if (motif === 'layers') {
  // Stacked rounded bars of varying width — a layered architecture stack.
  const count = 4 + Math.floor(rand() * 3); // 4–6 bars
  const gap = r2(between(7, 12));
  const barH = r2((H - 56 - gap * (count - 1)) / count);
  // Alignment mode changes the silhouette of the stack entirely.
  const align = ['left', 'center', 'stagger'][Math.floor(rand() * 3)];
  for (let i = 0; i < count; i++) {
    const w = r2(between(110, 240));
    const x =
      align === 'center'
        ? r2((W - w) / 2)
        : align === 'stagger'
          ? r2(i % 2 === 0 ? 30 + between(0, 14) : W - 30 - w - between(0, 14))
          : r2(34 + between(0, 20));
    layers.push({ x, y: r2(30 + i * (barH + gap)), w, h: barH });
  }
} else {
  // Vertical lanes of boxes — a pipeline / swimlane diagram. Lane count, lane
  // width, box counts and the wiring between lanes all vary, so two "lanes"
  // covers on the same page never read as the same picture.
  const count = 3 + Math.floor(rand() * 3); // 3–5 lanes
  const laneW = r2(between(34, 62) * (count > 4 ? 0.72 : 1));
  const span = W - 60;
  for (let i = 0; i < count; i++) {
    const x = r2(30 + laneW / 2 + (i * (span - laneW)) / (count - 1));
    const boxes: { y: number; h: number }[] = [];
    const n = 2 + Math.floor(rand() * 3); // 2–4 boxes per lane
    const gap = r2(between(9, 18));
    const avail = H - 52 - gap * (n - 1);
    const bh = r2(Math.min(36, avail / n));
    let y = 26 + between(0, Math.max(0, H - 52 - (bh * n + gap * (n - 1))));
    for (let b = 0; b < n; b++) {
      boxes.push({ y: r2(y), h: bh });
      y += bh + gap;
    }
    lanes.push({ x, w: laneW, boxes });
  }
  // Wire adjacent lanes together at randomly chosen boxes.
  for (let i = 0; i < lanes.length - 1; i++) {
    const a = lanes[i];
    const b = lanes[i + 1];
    const links = 1 + (rand() < 0.45 ? 1 : 0);
    for (let l = 0; l < links; l++) {
      const ba = a.boxes[Math.floor(rand() * a.boxes.length)];
      const bb = b.boxes[Math.floor(rand() * b.boxes.length)];
      const y1 = r2(ba.y + ba.h / 2);
      const y2 = r2(bb.y + bb.h / 2);
      const mx = r2((a.x + a.w / 2 + (b.x - b.w / 2)) / 2);
      wires.push(`M${r2(a.x + a.w / 2)} ${y1} H${mx} V${y2} H${r2(b.x - b.w / 2)}`);
    }
  }
}
---

{
  cover ? (
    <img
      src={cover}
      alt={alt}
      width={1280}
      height={720}
      loading="lazy"
      decoding="async"
      class:list={['cover-img', className]}
    />
  ) : (
    <div class:list={['cover-gen', className]} style={`--ha:${hueA};--hb:${hueB};`} aria-hidden="true">
      <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid slice" role="presentation" focusable="false">
        <defs>
          <pattern id={`${uid}-g`} width="16" height="16" patternUnits="userSpaceOnUse">
            <path d="M16 0H0V16" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.16" />
          </pattern>
          <linearGradient id={`${uid}-f`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="currentColor" stop-opacity="0.42" />
            <stop offset="100%" stop-color="currentColor" stop-opacity="0.1" />
          </linearGradient>
        </defs>

        <rect width={W} height={H} fill={`url(#${uid}-g)`} />

        {motif === 'nodes' && (
          <g transform={flipT}>
            {edges.map((e) => (
              <line
                x1={e.a.x}
                y1={e.a.y}
                x2={e.b.x}
                y2={e.b.y}
                stroke="currentColor"
                stroke-width="1"
                opacity="0.45"
              />
            ))}
            {nodes.map((n) => (
              <>
                <circle cx={n.x} cy={n.y} r={n.r + 4} fill="currentColor" opacity="0.12" />
                <circle cx={n.x} cy={n.y} r={n.r} fill={`url(#${uid}-f)`} stroke="currentColor" stroke-width="1" opacity="0.95" />
              </>
            ))}
          </g>
        )}

        {motif === 'arcs' && (
          <g transform={flipT}>
            {arcs.map((a) => (
              <circle
                cx="34"
                cy={H - 26}
                r={a.r}
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                stroke-dasharray={a.dash}
                opacity="0.4"
              />
            ))}
            {dots.map((d) => (
              <circle cx={d.x} cy={d.y} r={d.r} fill="currentColor" opacity="0.8" />
            ))}
            <circle cx="34" cy={H - 26} r="7" fill={`url(#${uid}-f)`} stroke="currentColor" stroke-width="1.2" />
          </g>
        )}

        {motif === 'layers' && (
          <g transform={flipT}>
            {layers.map((l) => (
              <>
                <rect
                  x={l.x}
                  y={l.y}
                  width={l.w}
                  height={l.h}
                  rx="4"
                  fill={`url(#${uid}-f)`}
                  stroke="currentColor"
                  stroke-width="1"
                  opacity="0.85"
                />
                <circle cx={l.x + 10} cy={l.y + l.h / 2} r="2.4" fill="currentColor" opacity="0.9" />
              </>
            ))}
          </g>
        )}

        {motif === 'lanes' && (
          <g transform={flipT}>
            {wires.map((d) => (
              <path d={d} fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
            ))}
            {lanes.map((ln) => (
              <>
                <line x1={ln.x} y1="20" x2={ln.x} y2={H - 20} stroke="currentColor" stroke-width="0.75" opacity="0.28" />
                {ln.boxes.map((b) => (
                  <rect
                    x={r2(ln.x - ln.w / 2)}
                    y={b.y}
                    width={ln.w}
                    height={b.h}
                    rx="4"
                    fill={`url(#${uid}-f)`}
                    stroke="currentColor"
                    stroke-width="1"
                    opacity="0.9"
                  />
                ))}
              </>
            ))}
          </g>
        )}
      </svg>
    </div>
  )
}

<style>
  .cover-img,
  .cover-gen {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* Hue comes from the slug; lightness/saturation come from the theme, so the
     same artwork reads correctly on both the dark and the light palette. */
  .cover-gen {
    position: relative;
    color: hsl(var(--ha) 72% 62%);
    background-image:
      radial-gradient(120% 100% at 12% 100%, hsl(var(--hb) 62% 22% / 0.85), transparent 62%),
      linear-gradient(140deg, hsl(var(--ha) 55% 15%), hsl(var(--hb) 48% 9%));
  }

  :global(html.light) .cover-gen {
    color: hsl(var(--ha) 48% 38%);
    background-image:
      radial-gradient(120% 100% at 12% 100%, hsl(var(--hb) 70% 88% / 0.9), transparent 62%),
      linear-gradient(140deg, hsl(var(--ha) 62% 94%), hsl(var(--hb) 55% 88%));
  }

  .cover-gen svg {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
