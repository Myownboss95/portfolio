---
// Dark/light toggle. No framework — just a tiny inline script island.
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="grid h-9 w-9 place-items-center rounded-md border border-app text-muted transition hover:text-accent"
>
  <svg class="sun h-4 w-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
  <svg class="moon h-4 w-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    const sun = btn.querySelector('.sun');
    const moon = btn.querySelector('.moon');
    function sync() {
      const isLight = document.documentElement.classList.contains('light');
      // Show the icon for the theme you'd switch TO.
      moon.classList.toggle('hidden', isLight);
      sun.classList.toggle('hidden', !isLight);
    }
    btn.addEventListener('click', function () {
      const isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
      sync();
    });
    sync();
  })();
</script>
