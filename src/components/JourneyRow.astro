---
import type { Job } from '../data/experience';

interface Props {
  job: Job;
  /** Stagger index for the `.reveal` scroll-in animation. */
  index: number;
  /** Homepage rows ship collapsed; this is here for future reuse. */
  open?: boolean;
}

const { job, index, open = false } = Astro.props;

// The data keeps company + descriptor in one string ("Hizo Africa — Pan-African
// Neobank", "Coriftech · TIVA Tech Africa · TECH4DEV"). The row wants the bare
// company name, so take the first segment before an em-dash or middot.
const companyName = job.company.split(/\s+[—·]\s+/)[0].trim();
const descriptor = job.company.slice(companyName.length).replace(/^\s*[—·]\s*/, '').trim();

// Monogram: up to two initials from the company name. No logo files exist and
// we deliberately do not hotlink external ones — this is a placeholder system,
// so it should look deliberate and consistent rather than "image missing".
const initials = companyName
  .split(/\s+/)
  .filter((w) => /[a-z0-9]/i.test(w))
  .slice(0, 2)
  .map((w) => w[0].toUpperCase())
  .join('');

// Deterministic per-company hue, so a company always gets the same tile colour
// across builds and pages. A djb2 hash picks from a curated set of
// well-separated hues (teal is excluded — that's the site accent, and tiles
// should not read as accent). Saturation/lightness are fixed in CSS, so every
// tile stays one family, differing only in hue.
const HUES = [212, 275, 330, 35, 100, 58];
let hash = 5381;
for (let i = 0; i < companyName.length; i++) {
  hash = (Math.imul(hash, 33) + companyName.charCodeAt(i)) >>> 0;
}
const hue = HUES[hash % HUES.length];

const count = job.points.length;
---

<details class="jr reveal group" open={open} style={`--i:${index}; --jr-hue:${hue}`}>
  <summary
    class="flex cursor-pointer list-none items-center gap-4 rounded-xl border border-app bg-card p-4 transition duration-200 hover:border-accent/60 sm:p-5"
  >
    <span class="jr-tile grid h-11 w-11 shrink-0 place-items-center rounded-lg font-mono text-sm font-bold sm:h-12 sm:w-12" aria-hidden="true">
      {initials}
    </span>

    <span class="min-w-0 flex-1">
      <span class="block truncate font-semibold text-main transition group-hover:text-accent">
        {companyName}
      </span>
      <span class="block truncate text-sm text-muted">{job.role}</span>
      <!-- Dates live on the right at ≥sm; on narrow screens they stack here. -->
      <span class="mt-1 flex items-center gap-1.5 font-mono text-xs text-faint sm:hidden">
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="16" rx="2" />
          <path d="M3 10h18M8 3v4M16 3v4" />
        </svg>
        {job.period}
      </span>
    </span>

    <span class="hidden shrink-0 items-center gap-1.5 font-mono text-xs text-faint sm:flex">
      <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="5" width="18" height="16" rx="2" />
        <path d="M3 10h18M8 3v4M16 3v4" />
      </svg>
      {job.period}
    </span>

    <svg
      class="jr-chevron h-4 w-4 shrink-0 text-faint transition-transform duration-300 group-hover:text-accent"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
  </summary>

  <div class="px-4 pb-5 pt-3 sm:px-5">
    <p class="font-mono text-xs text-faint">
      {descriptor && <span>{descriptor} · </span>}{job.location} · {count}{' '}
      {count === 1 ? 'highlight' : 'highlights'}
    </p>
    <ul class="mt-3 space-y-2">
      {
        job.points.map((p) => (
          <li class="flex gap-2 text-sm leading-relaxed text-muted">
            <span class="mt-[0.6em] h-px w-2.5 shrink-0 bg-accent/50" aria-hidden="true" />
            <span>{p}</span>
          </li>
        ))
      }
    </ul>
  </div>
</details>

<style>
  /* Strip the native disclosure triangle everywhere. */
  .jr > summary {
    list-style: none;
  }
  .jr > summary::-webkit-details-marker {
    display: none;
  }

  /* Monogram tile. Hue comes from the company name (see frontmatter); the rest
     of the recipe is fixed so all tiles read as one placeholder system. */
  .jr-tile {
    background: hsl(var(--jr-hue) 55% 50% / 0.16);
    border: 1px solid hsl(var(--jr-hue) 55% 55% / 0.32);
    color: hsl(var(--jr-hue) 62% 68%);
    letter-spacing: 0.02em;
  }
  :global(html.light) .jr-tile {
    background: hsl(var(--jr-hue) 60% 50% / 0.1);
    border-color: hsl(var(--jr-hue) 45% 45% / 0.28);
    color: hsl(var(--jr-hue) 55% 34%);
  }

  /* Open rows fuse with the detail panel below them. */
  .jr[open] > summary {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom-color: transparent;
  }
  .jr[open] .jr-chevron {
    transform: rotate(180deg);
  }
  .jr[open] > div {
    border: 1px solid var(--border);
    border-top: 0;
    border-bottom-left-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
    background: var(--bg-card);
  }

  /* CSS-only disclosure animation, same technique as ExperienceItem:
     `interpolate-size` makes `auto` interpolatable and `allow-discrete` keeps
     the panel rendered through the close. Unsupporting browsers snap open,
     which is the correct no-JS fallback. */
  .jr {
    interpolate-size: allow-keywords;
  }
  .jr::details-content {
    block-size: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      block-size 300ms ease,
      opacity 200ms ease,
      content-visibility 300ms;
    transition-behavior: allow-discrete;
  }
  .jr[open]::details-content {
    block-size: auto;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .jr::details-content,
    .jr[open]::details-content {
      transition: none;
      block-size: auto;
      opacity: 1;
    }
    .jr:not([open])::details-content {
      block-size: 0;
    }
    .jr-chevron {
      transition: none;
    }
  }
</style>
