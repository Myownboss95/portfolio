---
import { SITE, NAV } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-40 border-b border-app bg-app/80 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
    <a href="/" class="font-mono text-sm font-semibold tracking-tight text-main">
      daniel<span class="text-accent">.</span>odiachi
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-1.5 text-sm transition hover:text-accent',
              isActive(item.href) ? 'text-accent' : 'text-muted',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={SITE.resumeUrl}
        class="ml-1 hidden rounded-md border border-app px-3 py-1.5 text-sm text-main transition hover:border-accent hover:text-accent sm:inline-block"
      >
        Résumé
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
