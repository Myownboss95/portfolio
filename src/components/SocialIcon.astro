  },
  phone: {
    stroke: [
      'M7.2 3.5H4.6A1.6 1.6 0 0 0 3 5.2C3 13.4 10.6 21 18.8 21a1.6 1.6 0 0 0 1.7-1.6v-2.6a1 1 0 0 0-.8-1l-3.2-.7a1 1 0 0 0-1 .35l-1.1 1.35a13.6 13.6 0 0 1-5.6-5.6l1.35-1.1a1 1 0 0 0 .35-1l-.7-3.2a1 1 0 0 0-1-.8z',
    ],
  },
};

// Aliases so callers can pass either the SOCIALS label or a bare key.
const ALIASES: Record<string, string> = {
  x: 'xtwitter',
  twitter: 'xtwitter',
  mail: 'email',
  tel: 'phone',
  telephone: 'phone',
};

const key = label.toLowerCase().replace(/[^a-z0-9]/g, '');
const icon = ICONS[ALIASES[key] ?? key];
---

{
  icon && (
    <svg
      viewBox="0 0 24 24"
      width={size}
      height={size}
      class={className}
      aria-hidden="true"
      focusable="false"
    >
      {icon.fill && <path d={icon.fill} fill="currentColor" />}
      {icon.stroke?.map((d) => (
        <path
          d={d}
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      ))}
    </svg>
  )
}
