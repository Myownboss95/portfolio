---
// SocialIcon — the one place social glyphs live.
//
// Hand-authored inline SVG paths so the site stays fully self-contained: no
// icon package, no CDN, nothing to hotlink. Every icon is a 24x24 viewBox and
// paints with `currentColor`, so callers control size and colour from CSS.
//
// Optical weight: the brand marks (GitHub, LinkedIn, X, WhatsApp) are solid
// glyphs drawn at the same fill density; the two utility marks (Email, Phone)
// are 1.6px strokes on the same 24 grid, which reads at a matching weight at
// 16–20px. X and WhatsApp were checked against GitHub specifically — all three
// are simple-icons-derived outlines and share a stem thickness.

interface Props {
  /** Social label as it appears in SOCIALS, e.g. "GitHub" or "X (Twitter)". */
  label: string;
  /** Rendered pixel size. Defaults to 20. */
  size?: number;
  /** Extra classes for the <svg>. */
  class?: string;
}

const { label, size = 20, class: className } = Astro.props;

type IconDef = { fill?: string; stroke?: string[] };

// Keys are normalised (lowercase, non-alphanumerics stripped) so "X (Twitter)",
// "x", and "twitter" all resolve to the same mark.
const ICONS: Record<string, IconDef> = {
