---
/**
 * "Live GitHub activity" card — contribution heatmap + recent own-project activity.
 *
 * All data is fetched in this frontmatter at BUILD TIME and baked into the HTML.
 * There is no client-side fetch and no server runtime; see `src/lib/github.ts`.
 * If GitHub is unreachable the lib returns a committed snapshot, and if even that
 * is unusable it returns null and this component renders nothing.
 */
import { getGitHubActivity, type ContributionDay } from '../lib/github';

const data = await getGitHubActivity();

// --- Grid construction -------------------------------------------------------
// Columns are weeks (Sunday-first), rows are days of the week. Cells are placed
// explicitly by row/column so a partial first or last week can never misalign.
type Cell = ContributionDay & { row: number };
const weeks: Cell[][] = [];

if (data) {
  let current: Cell[] = [];
  for (const day of data.days) {
    // Parse as UTC — the dates are plain calendar dates, no timezone shifting.
    const row = new Date(`${day.date}T00:00:00Z`).getUTCDay(); // 0 = Sunday
    if (row === 0 && current.length > 0) {
      weeks.push(current);
      current = [];
    }
    current.push({ ...day, row });
  }
  if (current.length > 0) weeks.push(current);
}

// Month labels: label a column when its first day lands in a new month, keeping
// at least two columns of breathing room so labels never collide.
const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const monthLabels: { col: number; label: string }[] = [];
let lastMonth = -1;
let lastLabelCol = -99;
weeks.forEach((week, i) => {
  const month = new Date(`${week[0].date}T00:00:00Z`).getUTCMonth();
  if (month !== lastMonth && i - lastLabelCol >= 3 && i < weeks.length - 1) {
    monthLabels.push({ col: i + 1, label: MONTHS[month] });
    lastLabelCol = i;
  }
  lastMonth = month;
});

// --- Formatting --------------------------------------------------------------
const fmtLong = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
const fmtShort = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
  timeZone: 'UTC',
});

const cellLabel = (d: ContributionDay) =>
  `${d.count === 0 ? 'No' : d.count} contribution${d.count === 1 ? '' : 's'} on ${fmtLong.format(
    new Date(`${d.date}T00:00:00Z`)
  )}`;

const windowLabel = data
  ? `${fmtShort.format(new Date(`${data.rangeStart}T00:00:00Z`))} – ${fmtShort.format(
      new Date(`${data.rangeEnd}T00:00:00Z`)
    )}`
  : '';

const DOW = ['', 'Mon', '', 'Wed', '', 'Fri', ''];
---

{
  data && (
    <section class="mx-auto max-w-5xl px-5 py-16">
      <h2 class="text-2xl font-bold tracking-tight text-main">Live GitHub activity</h2>
      <p class="mt-2 max-w-2xl text-muted">
        Pulled from GitHub at build time — no dashboards, no hand-maintained numbers.
      </p>

      <div class="reveal mt-8 rounded-xl border border-app bg-card p-6">
        {/* Header */}
        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
          <div>
            <h3 class="text-base font-semibold text-main">Contribution graph</h3>
            <p class="mt-1 font-mono text-xs text-faint">
              {windowLabel} · @{data.username}
              {data.stale && <span class="text-muted"> · snapshot</span>}
            </p>
          </div>
          <a
            href={data.profileUrl}
            rel="noopener noreferrer"
            target="_blank"
            class="text-sm font-medium text-accent hover:underline"
          >
            View GitHub →
          </a>
        </div>

        {/* Heatmap — scrolls inside itself so the page body never scrolls sideways. */}
        <div class="gh-scroll mt-5" tabindex="0" role="group" aria-label="Contribution heatmap">
          <div class="gh-cal">
            <div aria-hidden="true" />
            <div
              class="gh-months"
              aria-hidden="true"
              style={`grid-template-columns: repeat(${weeks.length}, var(--gh-cell));`}
            >
              {monthLabels.map((m) => (
                <span style={`grid-column: ${m.col};`}>{m.label}</span>
              ))}
            </div>

            <div class="gh-dow" aria-hidden="true">
              {DOW.map((d) => (
                <span>{d}</span>
              ))}
            </div>

            <div class="gh-grid" role="grid" aria-label={`${data.total} contributions between ${windowLabel}`}>
              {weeks.map((week, col) =>
                week.map((day) => (
                  <span
                    class="gh-day"
                    data-date={day.date}
                    data-level={day.level}
                    role="gridcell"
                    aria-label={cellLabel(day)}
                    title={cellLabel(day)}
                    style={`grid-column: ${col + 1}; grid-row: ${day.row + 1};`}
                  />
                ))
              )}
            </div>
          </div>
        </div>

        {/* Footer: total + legend */}
        <div class="mt-4 flex flex-wrap items-center justify-between gap-x-6 gap-y-3 border-t border-app pt-4">
          <p class="font-mono text-xs text-muted">
            <span class="font-semibold text-main">{data.total.toLocaleString('en-GB')}</span>{' '}
            contributions in this window
          </p>
          <div class="flex items-center gap-1.5 font-mono text-xs text-faint">
            <span>Less</span>
            {[0, 1, 2, 3, 4].map((level) => (
              <span class="gh-day gh-legend" data-level={level} aria-hidden="true" />
            ))}
            <span>More</span>
          </div>
        </div>

      </div>
    </section>
  )
}

<style>
  .gh-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    /* Keep focus rings from being clipped by the scroll container. */
    padding-bottom: 2px;
    scrollbar-width: thin;
  }

  .gh-cal {
    --gh-cell: 11px;
    --gh-gap: 3px;
    display: grid;
    grid-template-columns: auto auto;
    gap: 4px 6px;
    width: max-content;
  }

  .gh-months {
    display: grid;
    gap: var(--gh-gap);
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: var(--text-faint);
  }
  .gh-months span {
    grid-row: 1;
    white-space: nowrap;
  }

  .gh-dow {
    display: grid;
    grid-template-rows: repeat(7, var(--gh-cell));
    gap: var(--gh-gap);
    align-items: center;
    font-family: var(--font-mono);
    font-size: 9px;
    line-height: 1;
    color: var(--text-faint);
    padding-right: 2px;
  }

  .gh-grid {
    display: grid;
    grid-template-rows: repeat(7, var(--gh-cell));
    grid-auto-columns: var(--gh-cell);
    gap: var(--gh-gap);
  }

  .gh-day {
    display: block;
    width: var(--gh-cell);
    height: var(--gh-cell);
    border-radius: 2px;
    background-color: var(--bg-soft);
    box-shadow: inset 0 0 0 1px var(--border);
    transition: transform 0.12s ease-out;
  }
  .gh-day:hover {
    transform: scale(1.35);
  }

  /* Teal heat scale, mixed against the card surface so it reads correctly in
     both themes (accent is #2dd4bf dark / #14b8a6 light). */
  .gh-day[data-level='1'] {
    background-color: color-mix(in srgb, var(--accent) 24%, var(--bg-soft));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 32%, transparent);
  }
  .gh-day[data-level='2'] {
    background-color: color-mix(in srgb, var(--accent) 48%, var(--bg-soft));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 52%, transparent);
  }
  .gh-day[data-level='3'] {
    background-color: color-mix(in srgb, var(--accent) 72%, var(--bg-soft));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 74%, transparent);
  }
  .gh-day[data-level='4'] {
    background-color: var(--accent);
    box-shadow: inset 0 0 0 1px var(--accent);
  }

  .gh-legend {
    /* Legend swatches are static — no hover zoom. */
    width: 10px;
    height: 10px;
  }
  .gh-legend:hover {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .gh-day {
      transition: none;
    }
    .gh-day:hover {
      transform: none;
    }
  }
</style>
