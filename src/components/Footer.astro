---
import { SITE, SOCIALS } from '../consts';
const year = 2026; // build-time constant; bump if needed
---

<footer class="border-t border-app bg-soft">
  <div class="mx-auto flex max-w-5xl flex-col gap-4 px-5 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-mono text-sm text-main">{SITE.name}</p>
      <p class="text-sm text-faint">{SITE.tagline}</p>
    </div>
    <div class="flex flex-wrap gap-x-5 gap-y-2">
      {
        SOCIALS.map((s) => (
          <a
            href={s.href}
            class="text-sm text-muted transition hover:text-accent"
            rel="noopener noreferrer"
            target={s.href.startsWith('http') ? '_blank' : undefined}
          >
            {s.label}
          </a>
        ))
      }
    </div>
  </div>
  <div class="mx-auto max-w-5xl px-5 pb-8">
    <p class="text-xs text-faint">© {year} {SITE.name}</p>
  </div>
</footer>
